# Copy this file to .env and fill in your Steam Web API key.
# Get a key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# (Optional) Your own Steam ID — auto-populates the profile search input in the UI.
# Find yours at: https://steamidfinder.com/
STEAM_ID=

# (Optional) Max parallel threads for fetching friend details. Default: 20
# Lower this if you hit Steam API rate limits.
GEAM_FRIENDS_WORKERS=20

# Set to 1 to enable Flask debug mode (development only — never use in production)
FLASK_DEBUG=0

# Copy this file to .env and fill in your values.
# Get a Steam Web API key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Your Steam ID (64-bit SteamID, e.g. 76561199168719281)
# Find it at: https://steamid.io
STEAM_ID=your_steam_id_here

# Set to 1 to enable Flask debug mode (development only — never use in production)
FLASK_DEBUG=0
